__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.Python

# Virtual environments
.venv/
.venv-*/
venv/
env/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/

